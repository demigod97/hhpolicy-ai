        "--read-only",
        "--project-ref=vnmsyofypuhxjlzwnuhh"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "sbp_92c50820738abd3dc3725e21e8b0ce7ae473b6a9"
      }
    },
   "playwright": {
      "command": "npx",
      "args": [
